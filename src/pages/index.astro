---
import "../styles/global.css";
import Header from "../components/layout/Header";
import Footer from "../components/layout/Footer";
import { ToastContainer } from "../components/ui/ToastContainer";
import PageContent from "../components/PageContent";
import AboutSection from "../components/about/AboutSection";
import BackToTopButton from "../components/ui/BackToTopButton";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon — SVG (modern browsers) + PNG fallbacks + ICO legacy -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <!-- Apple: PNG required (SVG not supported on iOS) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- SEO -->
    <title>LLM API Comparator — Compare AI Model Pricing</title>
    <meta
      name="description"
      content="Compare API costs for GPT-4, Claude, Gemini, Llama and more. Interactive calculator with real pricing data."
    />
    <meta
      name="keywords"
      content="LLM pricing, GPT-4 cost, Claude API price, Gemini pricing, AI model comparison"
    />
    <link rel="canonical" href="https://llm-comparator.abelgalloruiz.me/" />

    <!--
      Open Graph — used by Facebook, LinkedIn and most social platforms.
      LinkedIn reads og: tags natively; no separate linkedin: tags are needed.
    -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://llm-comparator.abelgalloruiz.me/" />
    <meta property="og:title" content="LLM API Comparator" />
    <meta
      property="og:description"
      content="Make data-driven decisions about which AI model fits your budget. Compare pricing and features of GPT-4, Claude, Gemini, Llama and more."
    />
    <!-- PNG is required: Facebook/LinkedIn/X crawlers do not render SVG -->
    <meta
      property="og:image"
      content="https://llm-comparator.abelgalloruiz.me/og-image.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta
      property="og:image:alt"
      content="LLM API Comparator — Compare AI Model Pricing & Costs"
    />
    <meta property="og:site_name" content="LLM API Comparator" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://llm-comparator.abelgalloruiz.me/" />
    <meta name="twitter:title" content="LLM API Comparator" />
    <meta
      name="twitter:description"
      content="Make data-driven decisions about which AI model fits your budget. Compare pricing and features of GPT-4, Claude, Gemini, Llama and more."
    />
    <meta
      name="twitter:image"
      content="https://llm-comparator.abelgalloruiz.me/og-image.png"
    />
    <meta
      name="twitter:image:alt"
      content="LLM API Comparator — Compare AI Model Pricing & Costs"
    />

    <!-- Additional Meta Tags -->
    <meta name="theme-color" content="#3b82f6" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="LLM Compare" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Anti-flash theme script: runs before React hydrates to prevent FOUC -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("llm-theme");
          var prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          var theme =
            stored === "dark" || stored === "light"
              ? stored
              : prefersDark
                ? "dark"
                : "light";
          if (theme === "dark") {
            document.documentElement.classList.add("dark");
          }
        } catch (e) {
          /* ignore – localStorage may be unavailable */
        }
      })();
    </script>

    <script defer src="https://umami.abelgalloruiz.me/script.js" data-website-id="a87adc4f-69b6-46f1-a376-04ab02053d59"></script>
  </head>

  <body class="min-h-screen transition-colors duration-300">
    <Header client:load />

    <main id="home" class="min-h-[80vh]">
      <PageContent client:load />
    </main>

    <Footer client:load />
    <ToastContainer client:load />
    <AboutSection client:load />
    <BackToTopButton client:load />
  </body>
</html>
